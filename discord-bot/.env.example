DISCORD_TOKEN=pon_tu_token_del_bot

# Prefijo de administracion. No es una keyword.
COMMAND_PREFIX=!bot

# Modo inicial para servidores nuevos. Despues se guarda por servidor con !bot autojoin.
# off: apagado. on: entra cuando alguien entra y el bot esta desconectado. most: sigue el canal con mas gente.
AUTO_JOIN_VOICE=most
AUTO_JOIN_MIN_MEMBERS=1
AUTO_JOIN_COOLDOWN_MS=5000
AUTO_JOIN_LEAVE_WHEN_EMPTY=true
AUTO_JOIN_EMPTY_CHECK_DELAY_MS=1200

# Si alguien desconecta al bot del canal de voz, vuelve al ultimo canal donde estaba.
REJOIN_ON_DISCONNECT=true
REJOIN_DELAY_MS=1500
REJOIN_MAX_ATTEMPTS=5

# Limpia mensajes escritos del bot y de quienes usaron el bot en el canal actual.
CLEAR_MESSAGES_COMMAND=!clear
CLEAR_SCAN_LIMIT=1000
CLEAR_MAX_SCAN_LIMIT=2000

# Evita que el bot conteste muchas veces seguidas en el mismo canal.
COOLDOWN_MS=1500

# true manda el mensaje como TTS de Discord. Necesita permiso "Send TTS Messages".
DISCORD_TTS=false

# true limita add/remove/clear/autojoin a gente con permiso Manage Server.
REQUIRE_MANAGE_GUILD_FOR_CONFIG=true

# true escribe mas eventos en data/debug.log para diagnosticar el bot.
DEBUG_MESSAGES=false

# Voz neuronal en espanol. Opciones buenas:
# es-AR-TomasNeural, es-AR-ElenaNeural, es-PY-TaniaNeural, es-PY-MarioNeural,
# es-ES-ElviraNeural, es-ES-AlvaroNeural, es-MX-DaliaNeural.
TTS_PROVIDER=edge
EDGE_TTS_VOICE=es-AR-TomasNeural
EDGE_TTS_RATE=+0%

# Menor valor = responde antes, pero puede cortar frases largas.
VOICE_SILENCE_MS=450

# Evita varias respuestas por una sola palabra hablada.
VOICE_TRIGGER_COOLDOWN_MS=3500

# Filtros contra falsos positivos de voz:
# VOICE_TRIGGER_MAX_EXTRA_WORDS=1 permite una palabra extra alrededor de la keyword.
# VOICE_TRIGGER_CONFIRM_WITH_FULL=short confirma con transcripcion libre solo keywords cortas.
# Opciones: off, short, all.
VOICE_TRIGGER_MAX_EXTRA_WORDS=1
VOICE_TRIGGER_CONFIRM_WITH_FULL=short
VOICE_TRIGGER_SHORT_MAX_CHARS=4
VOICE_WAKE_CONFIRM_WITH_FULL=true

# Aliases foneticos para palabras que Vosk no conoce.
# Formato: keyword:alias1,alias2;otra:alias1
VOICE_KEYWORD_ALIASES=peti:piti,pete,pedi,pity,petit

# Wake word especial para consultar al Codex CLI desde voz:
# ejemplo hablado: "experiencia como hago un bot de discord"
CODEX_ENABLED=true
CODEX_WAKE_WORD=experiencia
CODEX_MODEL=gpt-5.5
CODEX_REASONING_EFFORT=low
CODEX_TIMEOUT_MS=90000
CODEX_MAX_WORDS=20
CODEX_WAKE_COOLDOWN_MS=8000
CODEX_HOLD_MUSIC=false
CODEX_HOLD_MUSIC_VOLUME=0.18

# Modo personaje inicial para servidores nuevos:
# normal, bostero-termo, tio-borracho, relator-futbol, tecnico-ascenso, npc-kiosco
CODEX_CHARACTER_MODE=normal

# Palabras que suman al contador de excusas cuando aparecen en texto o voz.
EXCUSE_KEYWORDS=lag,tecla,bug
